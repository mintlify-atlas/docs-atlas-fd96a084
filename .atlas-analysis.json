  "keyFeatures": [
    "Minescript Plus API - Feature-rich API extension for Minescript mod",
    "Inventory Management - Click, shift-click, swap items in containers",
    "Screen & GUI - Manipulate titles, subtitles, actionbars, and screens",
    "World Interaction - Read/write signs, find entities, track block destruction",
    "Player & Server Info - Get game mode, latency, food level, tablist data",
    "Trading System - Interact with villager trading screens",
    "HUD Rendering - Display custom text and items on the HUD (requires Fabric API)",
    "WorldRender - Render boxes, blocks, text, points, lines, arrows, circles in-world",
    "Event System - Listen for title, subtitle, actionbar, and screen events",
    "Keybind System - Register custom keybinds with callbacks",
    "Config Library - JSON-backed configuration with attribute-style access",
    "SNBT Parser - Parse and manipulate Minecraft NBT data"
  ],
